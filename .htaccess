# Shared-hosting friendly entrypoint.
# Keep repository root as document root and route requests into /public.
DirectoryIndex index.php
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block direct web access to internal application folders.
  RewriteRule ^(app|config|database|routes|storage)(/|$) - [F,L]

  # Do not rewrite requests already targeting /public.
  RewriteCond %{REQUEST_URI} ^/public/ [NC]
  RewriteRule ^ - [L]

  # Route non-existing paths to /public.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
